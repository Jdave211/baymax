# Copy to .env (never commit .env). Used by DotEnv in the Mac app and by scripts/generate-site-config.mjs for the landing page.

# Supabase (public anon key + URL — still do not commit real values to git; use CI secrets)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cloudflare Worker (public URL)
WORKER_URL=https://clicky-proxy.baymac.workers.dev

# Stripe publishable key (safe to expose in browser; still inject via env for the static site)
STRIPE_PUBLISHABLE_KEY=

# PostHog (Mac app — optional; analytics disabled if unset)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Local API smoke test only (test_apis.swift)
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
